# Copy this to .env and fill in your values.
# Generate SECRET_KEY with: openssl rand -hex 32

APP_NAME=hedge-fund
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_TIMEZONE=America/New_York

SECRET_KEY=change_this_run_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ADMIN_USERNAME=dias
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=change_this_strong_password
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_PER_MINUTE=60

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hedgefund
POSTGRES_USER=hedgefund_user
POSTGRES_PASSWORD=change_this_db_password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT_SEC=5

TRADING_MODE=paper
ALPACA_LIVE_ENABLED=false

ALPACA_PAPER_API_KEY=your_paper_api_key_here
ALPACA_PAPER_SECRET_KEY=your_paper_secret_key_here
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_DATA_URL=https://data.alpaca.markets

ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
ALPACA_LIVE_DATA_URL=https://data.alpaca.markets
BROKER_HTTP_TIMEOUT_SEC=10
BROKER_RETRY_ATTEMPTS=3
BROKER_RETRY_BACKOFF_SEC=2

PAPER_INITIAL_CASH=100000
PAPER_SLIPPAGE_PCT=0.0005
PAPER_COMMISSION_USD=1.00
PAPER_FILL_MODEL=next_bar_open

YFINANCE_RETRY_ATTEMPTS=3
YFINANCE_RETRY_BACKOFF_SEC=5
YFINANCE_TIMEOUT_SEC=30
YFINANCE_BATCH_SIZE=10
HISTORICAL_BACKFILL_YEARS=5

SIGNAL_CONFIDENCE_THRESHOLD=0.65
MODEL_DIR=ml/models
FEATURE_LOOKBACK_DAYS=252
WALK_FORWARD_TEST_DAYS=252
ML_RANDOM_SEED=42
ML_N_JOBS=-1

MAX_POSITION_SIZE_PCT=0.15
MAX_SECTOR_EXPOSURE_PCT=0.40
STOP_LOSS_PCT=0.08
PORTFOLIO_DRAWDOWN_LIMIT=0.20
MAX_ORDERS_PER_DAY=10
MAX_ORDER_VOLUME_PCT=0.25
WASH_TRADE_WINDOW_DAYS=30

SCHEDULER_TIMEZONE=America/New_York
SCHEDULER_ENABLED=true
MARKET_CLOSE_HOUR=16
MARKET_CLOSE_MINUTE=30
JOB_FETCH_PRICES_ENABLED=true
JOB_COMPUTE_FEATURES_ENABLED=true
JOB_GENERATE_SIGNALS_ENABLED=true
JOB_EXECUTE_SIGNALS_ENABLED=false
JOB_CHECK_STOPS_ENABLED=false
JOB_RETRAIN_MODEL_ENABLED=false

DEFAULT_WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM,V,UNH
BENCHMARK_TICKER=SPY

VITE_API_BASE_URL=http://localhost:8000
VITE_POLLING_INTERVAL_MS=60000
VITE_APP_NAME=Personal Hedge Fund

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/hedgefund.log
LOG_ROTATION=weekly
LOG_RETENTION_DAYS=30

ALERTS_ENABLED=false
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

OLLAMA_ENABLED=false
OLLAMA_MODEL=llama3.2:3b
OLLAMA_MODEL_PATH=
OLLAMA_CONFIRM_THRESHOLD=0.5

TEST_DATABASE_URL=postgresql+psycopg://hedgefund_user:change_this_db_password@localhost:5432/hedgefund_test
TEST_REDIS_DB=15

FEATURE_BENCHMARK_COMPARISON=true
FEATURE_SECTOR_EXPOSURE_CHECK=false
FEATURE_WASH_TRADE_CHECK=true
FEATURE_INTRADAY_STOPS=true
