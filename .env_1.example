# ============================================================
# Personal Hedge Fund — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. Only .env.example is committed.
#
# Generate secrets with: openssl rand -hex 32
# ============================================================


# ============================================================
# APP
# ============================================================
APP_NAME=hedge-fund
APP_ENV=development                        # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true                             # set to false in production
APP_TIMEZONE=America/New_York

# ------------------------------------------------------------
# AUTH / SECURITY
# ------------------------------------------------------------
SECRET_KEY=change_this_run_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440                    # 24 hours

# Single-user credentials (no registration)
ADMIN_USERNAME=dias
ADMIN_PASSWORD_HASH=                        # bcrypt hash, generate via scripts/init_db.py
# Plaintext fallback only for first setup — remove after hashing:
ADMIN_PASSWORD=change_this_strong_password

# CORS — frontend origin(s), comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting (requests per minute, per IP)
RATE_LIMIT_PER_MINUTE=60


# ============================================================
# DATABASE — PostgreSQL
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hedgefund
POSTGRES_USER=hedgefund_user
POSTGRES_PASSWORD=change_this_db_password

# Connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30                         # seconds

# Full DSN (auto-built in config.py if not set)
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/hedgefund


# ============================================================
# CACHE — Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                            # blank if no auth
REDIS_DB=0
REDIS_TIMEOUT_SEC=5


# ============================================================
# TRADING MODE
# ============================================================
# "paper" = simulated trades only (safe, default)
# "live"  = real money via Alpaca (requires 2-step activation)
TRADING_MODE=paper

# Safety gate — must be "true" AND /settings/mode must be "live"
# Double-gating prevents accidental live trading
ALPACA_LIVE_ENABLED=false


# ============================================================
# ALPACA — Paper Trading
# Sign up (free): https://alpaca.markets → Paper Account
# ============================================================
ALPACA_PAPER_API_KEY=your_paper_api_key_here
ALPACA_PAPER_SECRET_KEY=your_paper_secret_key_here
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_DATA_URL=https://data.alpaca.markets


# ============================================================
# ALPACA — Live Trading
# ⚠️  WARNING: Real money. Only use after paper testing passes.
# ============================================================
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
ALPACA_LIVE_DATA_URL=https://data.alpaca.markets

# HTTP timeouts for broker calls
BROKER_HTTP_TIMEOUT_SEC=10
BROKER_RETRY_ATTEMPTS=3
BROKER_RETRY_BACKOFF_SEC=2


# ============================================================
# PAPER TRADING SIMULATION
# ============================================================
PAPER_INITIAL_CASH=100000                  # USD starting balance
PAPER_SLIPPAGE_PCT=0.0005                  # 0.05% per trade
PAPER_COMMISSION_USD=1.00                  # $1 per order
PAPER_FILL_MODEL=next_bar_open             # next_bar_open | same_bar_close


# ============================================================
# MARKET DATA (yfinance)
# ============================================================
YFINANCE_RETRY_ATTEMPTS=3
YFINANCE_RETRY_BACKOFF_SEC=5
YFINANCE_TIMEOUT_SEC=30
YFINANCE_BATCH_SIZE=10                     # tickers per batch request

# Historical data backfill window (in years)
HISTORICAL_BACKFILL_YEARS=5


# ============================================================
# ML STRATEGY
# ============================================================
SIGNAL_CONFIDENCE_THRESHOLD=0.65          # min to execute
MODEL_DIR=ml/models
FEATURE_LOOKBACK_DAYS=252                  # 1 trading year
WALK_FORWARD_TEST_DAYS=252
ML_RANDOM_SEED=42                          # reproducibility
ML_N_JOBS=-1                               # all CPU cores for training


# ============================================================
# RISK MANAGEMENT
# ============================================================
MAX_POSITION_SIZE_PCT=0.15                 # 15% max per ticker
MAX_SECTOR_EXPOSURE_PCT=0.40              # 40% max per sector
STOP_LOSS_PCT=0.08                         # −8% per position
PORTFOLIO_DRAWDOWN_LIMIT=0.20             # −20% kill-switch
MAX_ORDERS_PER_DAY=10
MAX_ORDER_VOLUME_PCT=0.25                  # 25% of avg daily volume
WASH_TRADE_WINDOW_DAYS=30                  # IRS wash-sale rule


# ============================================================
# SCHEDULER (APScheduler)
# ============================================================
SCHEDULER_TIMEZONE=America/New_York
SCHEDULER_ENABLED=true                     # set false in tests
MARKET_CLOSE_HOUR=16                       # 4 PM ET
MARKET_CLOSE_MINUTE=30

# Job-specific enable flags (for staged rollout)
JOB_FETCH_PRICES_ENABLED=true
JOB_COMPUTE_FEATURES_ENABLED=true
JOB_GENERATE_SIGNALS_ENABLED=true
JOB_EXECUTE_SIGNALS_ENABLED=false          # turn on after Phase 3
JOB_CHECK_STOPS_ENABLED=false              # turn on after Phase 4
JOB_RETRAIN_MODEL_ENABLED=false            # turn on after Phase 2


# ============================================================
# WATCHLIST — Default Tickers
# ============================================================
DEFAULT_WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM,V,UNH
BENCHMARK_TICKER=SPY


# ============================================================
# FRONTEND (Vite)
# ============================================================
VITE_API_BASE_URL=http://localhost:8000
VITE_POLLING_INTERVAL_MS=60000             # dashboard refresh (60s)
VITE_APP_NAME=Personal Hedge Fund


# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                            # json | console
LOG_FILE=logs/hedgefund.log
LOG_ROTATION=weekly                        # daily | weekly
LOG_RETENTION_DAYS=30


# ============================================================
# ALERTING (optional, for Phase 5+)
# ============================================================
# Email alerts for kill-switch, errors, daily P&L summary
ALERTS_ENABLED=false
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Telegram alerts (alternative / additional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ============================================================
# TESTING (only used in pytest)
# ============================================================
TEST_DATABASE_URL=postgresql+psycopg://hedgefund_user:change_this_db_password@localhost:5432/hedgefund_test
TEST_REDIS_DB=15                           # separate Redis DB for tests


# ============================================================
# FEATURE FLAGS (for gradual rollout)
# ============================================================
FEATURE_BENCHMARK_COMPARISON=true
FEATURE_SECTOR_EXPOSURE_CHECK=false        # enable after sector mapping added
FEATURE_WASH_TRADE_CHECK=true
FEATURE_INTRADAY_STOPS=true
